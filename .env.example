# Supabase/Postgres connection string (Session Pooler recommended for Vercel)
# Example: postgresql://USER:PASSWORD@HOST:PORT/dbname
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/statestats"

# Direct Postgres connection (used by Prisma migrate commands)
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/statestats"

# Optional API keys (real ingestion when set; synthetic fallback when unset)
# CENSUS_API_KEY="your-census-api-key"
# BLS_API_KEY="your-bls-api-key"

# Optional: limit ingestion to N trailing years from latest available API year
# INGEST_LOOKBACK_YEARS="25"

# Required for POST /api/admin/ingest
# ADMIN_INGEST_SECRET="replace-with-long-random-secret"
